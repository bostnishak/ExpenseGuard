# ══════════════════════════════════════════════════════════════
# ExpenseGuard Pro — Environment Variables (.env)
# 
# DİKKAT: Bu dosyayı '.env' olarak kopyalayın ve şifreleri değiştirin.
# Kesinlikle .env dosyasını git vb. repolara PUSH ETMEYİN.
# ══════════════════════════════════════════════════════════════

# ── POSTGRESQL ──────────────────────────────────────────────
POSTGRES_USER=eguser
POSTGRES_PASSWORD=YourSuperStrongPostgresPassword123!

# ── API SECURITY ────────────────────────────────────────────
# JWT secret minimum 32 karakter olmalıdır.
JWT_SECRET=YourSuperStrongJwtSecretKey_MinimumLength32Chars!

# AES 256 GCM Şifreleme Anahtarı. 
# Veritabanındaki hassas verileri kriptolar. Kaybolursa veriler kurtarılamaz!
ENCRYPTION_KEY=YourSuperStrongEncryptionKey_Change_In_Production_2024!
INTERNAL_API_SECRET=YourSuperStrongInternalApiSecret!

# ── AI SERVICE ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
